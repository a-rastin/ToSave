# ---- Database ----
POSTGRES_USER=gord
POSTGRES_PASSWORD=gord
POSTGRES_DB=gord
# Used by the backend (async driver). When running via docker-compose, host is "db".
DATABASE_URL=postgresql+asyncpg://gord:gord@db:5432/gord

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Auth ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- App ----
ALLOW_SIGNUP=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- AI (optional; left blank = local fallback parser) ----
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Integrations (skipped in MVP; placeholders for later) ----
GOOGLE_DRIVE_REFRESH_TOKEN=
TELEGRAM_N8N_WEBHOOK_URL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
